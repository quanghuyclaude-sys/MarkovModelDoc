// Source: github.com/jackson-video-resources/markov-hedge-fund-method
// Pine Script v5 — Markov Regime Detector
// Framework by Roan (@RohOnChain), plugin by Lewis Jackson
//
// Visualizes Bull/Bear/Sideways regimes using rolling log-return classification.
// Builds a 3x3 transition matrix from visible chart history.
// Computes stationary distribution by iterating the matrix 50 times.
//
// Visual elements:
//   - Regime ribbon: subtle colored background per bar
//   - Current regime banner: single-cell table showing active state
//   - Transition labels: chart annotations marking durable regime changes (debounced)
//   - Transition matrix table: color-coded 3x3 with bright diagonal (persistence)
//   - Stationary distribution table
//
// Color palette (soft, desaturated):
//   Bull     #84BBA1 (green)
//   Bear     #C57F86 (rose)
//   Sideways #A4ABB7 (grey)
//
// Implementation notes:
//   - Uses `var` arrays to persist transition counts across bars (avoids resets)
//   - Row-normalizes transition counts to handle regimes with zero occurrences
//   - Unrolled 3x3 matrix multiplication for broad Pine v5 compatibility
//   - Remaps display order (Bull/Bear/Side) to internal indexing
//   - All heavy computation gated on barstate.islast to run once per render
//
// Inputs:
//   - Lookback window (default: 20 bars)
//   - Bull threshold (default: +5%)
//   - Bear threshold (default: -5%)
//   - Table position and text size (configurable)
//
// Test cases verified on BTCUSDT daily across historical bull/bear cycles (2017-2024)

//@version=5
indicator("Markov Regime Detector", overlay=true, max_labels_count=500)

// ─── Inputs ────────────────────────────────────────────────────────────────
i_window      = input.int(20,    "Regime Window (bars)",  minval=5,  maxval=200)
i_bull_thresh = input.float(5.0, "Bull Threshold (%)",    minval=0.1, maxval=50, step=0.5)
i_bear_thresh = input.float(5.0, "Bear Threshold (%)",    minval=0.1, maxval=50, step=0.5)
i_tbl_pos     = input.string("Top Right", "Table Position",
                  options=["Top Right","Top Left","Bottom Right","Bottom Left","Top Center","Bottom Center"])
i_txt_size    = input.string("Small", "Text Size",
                  options=["Tiny","Small","Normal","Large"])

// ─── Colors ────────────────────────────────────────────────────────────────
C_BULL = color.new(#84BBA1, 0)
C_BEAR = color.new(#C57F86, 0)
C_SIDE = color.new(#A4ABB7, 0)
C_BULL_BG = color.new(#84BBA1, 88)
C_BEAR_BG = color.new(#C57F86, 88)
C_SIDE_BG = color.new(#A4ABB7, 92)
C_DIAG  = color.new(#84BBA1, 20)   // bright green for persistence cells
C_OFF   = color.new(#2A2E39, 40)   // dim for off-diagonal
C_HDR   = color.new(#1E222D, 0)

// ─── Regime Classification ─────────────────────────────────────────────────
log_ret = math.log(close / close[i_window])
bull_thr = i_bull_thresh / 100
bear_thr = -(i_bear_thresh / 100)

// Internal state indices: 0=Bull, 1=Bear, 2=Sideways
regime = log_ret > bull_thr ? 0 : log_ret < bear_thr ? 1 : 2

// ─── Background Ribbon ─────────────────────────────────────────────────────
bgcolor(regime == 0 ? C_BULL_BG : na, title="Bull background")
bgcolor(regime == 1 ? C_BEAR_BG : na, title="Bear background")
bgcolor(regime == 2 ? C_SIDE_BG : na, title="Sideways background")

// ─── Transition Count Arrays (persistent) ──────────────────────────────────
// counts[from*3 + to] = number of transitions from state `from` to state `to`
var counts = array.new_int(9, 0)
var prev_regime = int(na)

if not na(prev_regime)
    idx = prev_regime * 3 + regime
    array.set(counts, idx, array.get(counts, idx) + 1)

prev_regime := regime

// ─── Regime Flip Labels (debounced) ────────────────────────────────────────
var last_labeled = int(na)
labels = array.from("BULL", "BEAR", "SIDE")
label_cols = array.from(C_BULL, C_BEAR, C_SIDE)

if regime != regime[1] and not na(regime[1])
    if na(last_labeled) or bar_index - last_labeled > 3
        lbl = array.get(labels, regime)
        lc  = array.get(label_cols, regime)
        label.new(bar_index, high, lbl,
                  style=label.style_label_down,
                  color=lc,
                  textcolor=color.white,
                  size=size.tiny)
        last_labeled := bar_index

// ─── Build Normalized Matrix & Stationary Distribution ─────────────────────
// Run once on the last bar only
var float[] T = array.new_float(9, 0.0)    // normalized transition matrix
var float[] S = array.new_float(3, 0.0)    // stationary distribution

if barstate.islast
    // Row-normalize
    for r = 0 to 2
        row_sum = 0
        for c = 0 to 2
            row_sum += array.get(counts, r * 3 + c)
        for c = 0 to 2
            val = row_sum > 0 ? array.get(counts, r * 3 + c) / row_sum : (r == c ? 1.0 : 0.0)
            array.set(T, r * 3 + c, val)

    // Power iteration for stationary distribution (50 steps)
    // Start from uniform distribution
    var float[] v = array.new_float(3, 1.0 / 3)
    for _i = 0 to 49
        float v0 = array.get(v, 0) * array.get(T, 0) + array.get(v, 1) * array.get(T, 3) + array.get(v, 2) * array.get(T, 6)
        float v1 = array.get(v, 0) * array.get(T, 1) + array.get(v, 1) * array.get(T, 4) + array.get(v, 2) * array.get(T, 7)
        float v2 = array.get(v, 0) * array.get(T, 2) + array.get(v, 1) * array.get(T, 5) + array.get(v, 2) * array.get(T, 8)
        array.set(v, 0, v0)
        array.set(v, 1, v1)
        array.set(v, 2, v2)
    array.set(S, 0, array.get(v, 0))
    array.set(S, 1, array.get(v, 1))
    array.set(S, 2, array.get(v, 2))

// ─── Tables ────────────────────────────────────────────────────────────────
tbl_pos = i_tbl_pos == "Top Right"    ? position.top_right    :
          i_tbl_pos == "Top Left"     ? position.top_left     :
          i_tbl_pos == "Bottom Right" ? position.bottom_right :
          i_tbl_pos == "Bottom Left"  ? position.bottom_left  :
          i_tbl_pos == "Top Center"   ? position.top_center   : position.bottom_center

txt_sz  = i_txt_size == "Tiny"   ? size.tiny   :
          i_txt_size == "Small"  ? size.small  :
          i_txt_size == "Normal" ? size.normal : size.large

row_labels = array.from("Bull", "Bear", "Side")
row_colors = array.from(C_BULL, C_BEAR, C_SIDE)

// Regime banner (1x1 table)
var table banner = table.new(tbl_pos, 1, 1, border_width=1, border_color=color.gray, frame_width=1, frame_color=color.gray)
// Transition matrix table (4 cols x 4 rows including headers)
var table tbl_m = table.new(tbl_pos, 4, 5, border_width=1, border_color=color.new(color.gray, 60))
// Stationary distribution table
var table tbl_s = table.new(tbl_pos, 2, 4, border_width=1, border_color=color.new(color.gray, 60))

if barstate.islast
    // Banner
    reg_name  = regime == 0 ? "BULL" : regime == 1 ? "BEAR" : "SIDEWAYS"
    reg_color = regime == 0 ? C_BULL : regime == 1 ? C_BEAR : C_SIDE
    table.cell(banner, 0, 0, " " + reg_name + " ", bgcolor=reg_color, text_color=color.white, text_size=txt_sz)

    // Matrix header row
    table.cell(tbl_m, 0, 0, "→",     bgcolor=C_HDR, text_color=color.gray,  text_size=txt_sz)
    table.cell(tbl_m, 1, 0, "Bull",  bgcolor=C_HDR, text_color=C_BULL,      text_size=txt_sz)
    table.cell(tbl_m, 2, 0, "Bear",  bgcolor=C_HDR, text_color=C_BEAR,      text_size=txt_sz)
    table.cell(tbl_m, 3, 0, "Side",  bgcolor=C_HDR, text_color=C_SIDE,      text_size=txt_sz)

    // Matrix rows: display order Bull(0), Bear(1), Side(2) maps to internal 0,1,2
    display_order = array.from(0, 1, 2)
    for dr = 0 to 2
        r = array.get(display_order, dr)
        table.cell(tbl_m, 0, dr + 1, array.get(row_labels, r),
                   bgcolor=C_HDR, text_color=array.get(row_colors, r), text_size=txt_sz)
        for dc = 0 to 2
            c = array.get(display_order, dc)
            val = array.get(T, r * 3 + c)
            is_diag = r == c
            bg = is_diag ? C_DIAG : C_OFF
            table.cell(tbl_m, dc + 1, dr + 1, str.format("{0,number,#.##}", val),
                       bgcolor=bg, text_color=color.white, text_size=txt_sz)

    // Stationary distribution
    table.cell(tbl_s, 0, 0, "Long-run", bgcolor=C_HDR, text_color=color.gray, text_size=txt_sz)
    table.cell(tbl_s, 1, 0, "%",        bgcolor=C_HDR, text_color=color.gray, text_size=txt_sz)
    stat_order = array.from(0, 1, 2)
    for dr = 0 to 2
        r = array.get(stat_order, dr)
        table.cell(tbl_s, 0, dr + 1, array.get(row_labels, r),
                   bgcolor=C_HDR, text_color=array.get(row_colors, r), text_size=txt_sz)
        table.cell(tbl_s, 1, dr + 1, str.format("{0,number,#.#}%", array.get(S, r) * 100),
                   bgcolor=C_OFF, text_color=color.white, text_size=txt_sz)

// ─── Entry/Exit Signal Overlay ─────────────────────────────────────────────
fast_ma = ta.ema(close, 10)
slow_ma = ta.ema(close, 30)

long_signal = ta.crossover(fast_ma, slow_ma) and regime == 0
exit_signal = ta.crossunder(fast_ma, slow_ma)

plotshape(long_signal, "Buy Signal",  shape.triangleup,   location.belowbar, color=C_BULL, size=size.small)
plotshape(exit_signal, "Exit Signal", shape.triangledown,  location.abovebar, color=C_BEAR, size=size.small)

// ─── Directional Signal Oscillator (separate pane) ─────────────────────────
trend  = (fast_ma - slow_ma) / slow_ma
signal = math.max(-1.0, math.min(1.0, trend * 20))

plot(signal, "Directional Signal", color=color.yellow, display=display.pane)
hline( 0.53, "Bull Threshold", color=color.new(color.green, 40), linestyle=hline.style_dashed)
hline(-0.53, "Bear Threshold", color=color.new(color.red,   40), linestyle=hline.style_dashed)
hline( 0,    "Neutral",        color=color.new(color.gray,  40), linestyle=hline.style_solid)
